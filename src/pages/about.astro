---
import SiteLayout from "../layouts/SiteLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { clinics } from "../data/clinics";

const totalDoctors = clinics.reduce((sum, clinic) => sum + clinic.doctors.length, 0);

const values = [
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" /></svg>`,
    title: "Collaborative Care",
    description: "Our practitioners work together, sharing insights and coordinating treatment plans to provide comprehensive care."
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>`,
    title: "Patient-Centered",
    description: "Every decision we make is guided by what's best for our patients' health and wellbeing."
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5" /></svg>`,
    title: "Evidence-Based",
    description: "We combine proven medical practices with the latest research to deliver effective treatments."
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v17.25m0 0c-1.472 0-2.882.265-4.185.75M12 20.25c1.472 0 2.882.265 4.185.75M18.75 4.97A48.416 48.416 0 0012 4.5c-2.291 0-4.545.16-6.75.47m13.5 0c1.01.143 2.01.317 3 .52m-3-.52l2.62 10.726c.122.499-.106 1.028-.589 1.202a5.988 5.988 0 01-2.031.352 5.988 5.988 0 01-2.031-.352c-.483-.174-.711-.703-.59-1.202L18.75 4.971zm-16.5.52c.99-.203 1.99-.377 3-.52m0 0l2.62 10.726c.122.499-.106 1.028-.589 1.202a5.989 5.989 0 01-2.031.352 5.989 5.989 0 01-2.031-.352c-.483-.174-.711-.703-.59-1.202L5.25 4.971z" /></svg>`,
    title: "Integrated Approach",
    description: "Multiple healthcare disciplines under one roof means more convenient, coordinated care for you."
  }
];
---
<SiteLayout title="About – Integrated Health Professional Centre">
  <Fragment slot="header"><Header /></Fragment>

  <!-- Page Header -->
  <section class="bg-gradient-to-br from-slate-50 via-white to-teal-50 py-12 md:py-16">
    <div class="container">
      <h1>About IHPC</h1>
      <p class="mt-4 text-lg text-slate-600 max-w-2xl">
        Learn more about the Integrated Health Professional Centre and our commitment
        to providing exceptional healthcare in Bedford.
      </p>
    </div>
  </section>

  <!-- About Content -->
  <section class="section">
    <div class="container">
      <div class="grid gap-12 lg:grid-cols-2 items-center">
        <div>
          <h2>A New Model for Healthcare</h2>
          <p class="mt-4 text-lg text-slate-600">
            The Integrated Health Professional Centre (IHPC) is a co-owned medical
            building that brings together independent healthcare practices under one roof.
            Our unique model allows each clinic to maintain its independence while
            benefiting from shared resources and collaborative opportunities.
          </p>
          <p class="mt-4 text-slate-600">
            Located at 1378 Bedford Highway, we provide a welcoming environment where
            family medicine, naturopathic care, and pain management specialists work
            alongside each other. This integrated approach means our patients can access
            diverse healthcare services conveniently, with practitioners who communicate
            and collaborate when needed.
          </p>
          <p class="mt-4 text-slate-600">
            Our shared waiting area ensures a seamless experience for all patients,
            while each clinic maintains its own scheduling, billing, and patient
            relationships.
          </p>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-6 rounded-2xl bg-teal-50 text-center">
            <p class="text-4xl font-bold text-teal-600">{clinics.length}</p>
            <p class="mt-1 text-slate-600">Clinics</p>
          </div>
          <div class="p-6 rounded-2xl bg-teal-50 text-center">
            <p class="text-4xl font-bold text-teal-600">{totalDoctors}</p>
            <p class="mt-1 text-slate-600">Practitioners</p>
          </div>
          <div class="p-6 rounded-2xl bg-slate-100 text-center">
            <p class="text-4xl font-bold text-slate-700">3</p>
            <p class="mt-1 text-slate-600">Specialties</p>
          </div>
          <div class="p-6 rounded-2xl bg-slate-100 text-center">
            <p class="text-4xl font-bold text-slate-700">1</p>
            <p class="mt-1 text-slate-600">Convenient Location</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Our Values -->
  <section class="section bg-white">
    <div class="container">
      <div class="section-header">
        <h2>Our Values</h2>
        <p>The principles that guide everything we do at IHPC.</p>
      </div>

      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-4">
        {values.map((value) => (
          <div class="text-center">
            <div class="w-14 h-14 mx-auto rounded-2xl bg-teal-100 flex items-center justify-center text-teal-600">
              <Fragment set:html={value.icon} />
            </div>
            <h3 class="mt-4 text-lg font-semibold">{value.title}</h3>
            <p class="mt-2 text-slate-600">{value.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Facility -->
  <section class="section gradient-subtle">
    <div class="container">
      <div class="grid gap-12 lg:grid-cols-2 items-center">
        <div class="order-2 lg:order-1">
          <div class="aspect-[4/3] rounded-2xl bg-gradient-to-br from-teal-100 to-cyan-100 flex items-center justify-center">
            <div class="text-center p-8">
              <div class="w-20 h-20 mx-auto rounded-full bg-white shadow-lg flex items-center justify-center">
                <svg class="w-10 h-10 text-teal-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3.75h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008z" />
                </svg>
              </div>
              <p class="mt-4 text-slate-600">Professional medical facility</p>
            </div>
          </div>
        </div>
        <div class="order-1 lg:order-2">
          <h2>Our Facility</h2>
          <p class="mt-4 text-lg text-slate-600">
            Our modern facility on Bedford Highway is designed with patient comfort
            and accessibility in mind.
          </p>

          <ul class="mt-6 space-y-4">
            <li class="flex items-start gap-3">
              <svg class="w-6 h-6 text-teal-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <div>
                <p class="font-medium text-slate-900">Accessible Entry</p>
                <p class="text-slate-600">Fully accessible building entrance and facilities</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-6 h-6 text-teal-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <div>
                <p class="font-medium text-slate-900">On-Site Parking</p>
                <p class="text-slate-600">Convenient free parking available for patients</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-6 h-6 text-teal-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <div>
                <p class="font-medium text-slate-900">Transit Access</p>
                <p class="text-slate-600">Easily accessible via Bedford Highway bus routes</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-6 h-6 text-teal-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <div>
                <p class="font-medium text-slate-900">Shared Reception</p>
                <p class="text-slate-600">Welcoming front desk to assist all patients</p>
              </div>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Location -->
  <section class="section bg-white">
    <div class="container">
      <div class="max-w-2xl mx-auto text-center">
        <h2>Visit Us</h2>
        <p class="mt-4 text-lg text-slate-600">
          We're conveniently located on Bedford Highway, serving patients from
          Bedford, Halifax, Sackville, and surrounding communities.
        </p>

        <div class="mt-8 p-6 rounded-2xl bg-slate-50 inline-block">
          <p class="text-xl font-medium text-slate-900">1378 Bedford Highway</p>
          <p class="text-slate-600">Bedford, NS B4A 1E2</p>
        </div>

        <div class="mt-8">
          <a href="/contact" class="btn btn-primary">
            Get Directions
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <Fragment slot="footer"><Footer /></Fragment>
</SiteLayout>
