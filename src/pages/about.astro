---
import SiteLayout from "../layouts/SiteLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { clinics } from "../data/clinics";



---
<SiteLayout title="About - Integrated Health Professional Centre">
  <Fragment slot="header"><Header /></Fragment>

  <!-- Page Header -->
  <section class="bg-gradient-to-br from-white via-teal-50 to-teal-100 py-12 md:py-16">
    <div class="container">
      <h1>About IHPC</h1>
      <p class="mt-4 text-lg text-slate-600 max-w-2xl">
        Learn more about the Integrated Health Professional Centre and our commitment
        to providing exceptional healthcare in Bedford.
      </p>
    </div>
  </section>

  <!-- About Content -->
  <section class="section bg-slate-50">
    <div class="container">
      <div class="grid gap-12 lg:grid-cols-2 items-center">
        <div>
          <h2>Your Health Needs, Under One Roof</h2>
          <p class="mt-4 text-lg text-slate-600">
            The Integrated Health Professional Centre (IHPC) is a co-owned medical
            building that brings together independent healthcare practices under one roof.
            Our unique model allows each clinic to maintain full independence while
            benefiting from a modern, shared facility.
          </p>
          <p class="mt-4 text-slate-600">
            Located at 1378 Bedford Highway, we provide a welcoming environment where
            family medicine, naturopathic medicine and a pain management specialist work
            alongside each other. Patients benefit from the convenience of accessing
            diverse healthcare services at a single address.
          </p>
          <p class="mt-4 text-slate-600">
            Our shared waiting area and professional setting create a comfortable
            experience for all patients, while each clinic maintains its own scheduling,
            billing, reception and patient relationships.
          </p>
        </div>
        <div class="space-y-3">
          {clinics.flatMap((clinic) => clinic.doctors.map((doctor) => (
            <a href={`/clinics/${clinic.slug}`} class="flex items-center gap-4 p-4 rounded-xl bg-white border border-slate-100 shadow-sm hover:border-teal-200 hover:shadow-md transition-all group">
              {doctor.photo ? (
                <img
                  src={doctor.photo}
                  alt={doctor.name}
                  class="w-14 h-14 rounded-full object-cover shrink-0"
                />
              ) : (
                <div class="w-14 h-14 rounded-full bg-gradient-to-br from-teal-400 to-teal-600 flex items-center justify-center text-white font-semibold shrink-0">
                  {doctor.name.split(' ').slice(1).map((n: string) => n[0]).join('')}
                </div>
              )}
              <div class="min-w-0">
                <p class="font-semibold text-slate-900 group-hover:text-teal-700 transition-colors">{doctor.name}, {doctor.credentials}</p>
                <p class="text-sm text-teal-600 mt-0.5">{clinic.tagline}</p>
              </div>
            </a>
          )))}
        </div>
      </div>
    </div>
  </section>

  <!-- Facility -->
  <section class="section bg-white">
    <div class="container">
      <div class="grid gap-12 lg:grid-cols-2 items-center">
        <div class="order-2 lg:order-1">
          <div class="aspect-[4/3] rounded-2xl bg-gradient-to-br from-teal-100 to-cyan-100 flex items-center justify-center">
            <div class="text-center p-8">
              <div class="w-20 h-20 mx-auto rounded-full bg-white shadow-lg flex items-center justify-center">
                <svg class="w-10 h-10 text-teal-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3.75h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008z" />
                </svg>
              </div>
              <p class="mt-4 text-slate-600">Professional medical facility</p>
            </div>
          </div>
        </div>
        <div class="order-1 lg:order-2">
          <h2>Our Facility</h2>
          <p class="mt-4 text-lg text-slate-600">
            Our modern facility on Bedford Highway is designed with patient comfort
            and accessibility in mind.
          </p>

          <ul class="mt-6 space-y-4">
            <li class="flex items-start gap-3">
              <svg class="w-6 h-6 text-teal-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <div>
                <p class="font-medium text-slate-900">Accessible Entry</p>
                <p class="text-slate-600">Fully accessible building entrance and facilities</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-6 h-6 text-teal-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <div>
                <p class="font-medium text-slate-900">On-Site Parking</p>
                <p class="text-slate-600">Convenient free parking available for patients</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-6 h-6 text-teal-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <div>
                <p class="font-medium text-slate-900">Transit Access</p>
                <p class="text-slate-600">Easily accessible via Bedford Highway bus routes</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-6 h-6 text-teal-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <div>
                <p class="font-medium text-slate-900">Shared Waiting Area</p>
                <p class="text-slate-600">Comfortable shared waiting area serving all three clinics</p>
              </div>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Location -->
  <section class="section bg-slate-50">
    <div class="container">
      <div class="max-w-2xl mx-auto text-center">
        <h2>Visit Us</h2>
        <p class="mt-4 text-lg text-slate-600">
          We're conveniently located on Bedford Highway, serving patients from
          Bedford, Halifax, Dartmouth, Sackville and surrounding communities.
        </p>

        <div class="mt-8 p-6 rounded-2xl bg-slate-50 inline-block">
          <p class="text-xl font-medium text-slate-900">1378 Bedford Highway</p>
          <p class="text-slate-600">Bedford, NS B4A 1E2</p>
        </div>

        <div class="mt-8">
          <a href="/contact" class="btn btn-primary">
            Get Directions
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <Fragment slot="footer"><Footer /></Fragment>
</SiteLayout>
