---
import SiteLayout from "../layouts/SiteLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { clinics } from "../data/clinics";

const services = [
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" /></svg>`,
    title: "Family Medicine",
    description: "Comprehensive primary care for patients of all ages, from routine checkups to chronic disease management."
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5" /></svg>`,
    title: "Naturopathic Medicine",
    description: "Evidence-based natural healthcare combining traditional healing wisdom with modern scientific research."
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" /></svg>`,
    title: "Pain Management",
    description: "Specialized care for chronic pain conditions using comprehensive assessment and injection therapies."
  }
];

const features = [
  "Multiple healthcare disciplines under one roof",
  "Coordinated care between practitioners",
  "Convenient Bedford Highway location",
  "Accessible facilities with on-site parking",
  "Shared reception for streamlined service"
];
---
<SiteLayout>
  <Fragment slot="header"><Header /></Fragment>

  <!-- Hero Section -->
  <section class="relative overflow-hidden bg-gradient-to-br from-slate-50 via-white to-teal-50">
    <div class="absolute inset-0 bg-[url('data:image/svg+xml,%3Csvg width=\"30\" height=\"30\" viewBox=\"0 0 30 30\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\"%3E%3Cpath d=\"M1.22676 0C1.91374 0 2.45351 0.539773 2.45351 1.22676C2.45351 1.91374 1.91374 2.45351 1.22676 2.45351C0.539773 2.45351 0 1.91374 0 1.22676C0 0.539773 0.539773 0 1.22676 0Z\" fill=\"rgba(15,118,110,0.07)\"%3E%3C/path%3E%3C/svg%3E')] opacity-60"></div>
    <div class="container relative">
      <div class="py-16 md:py-24 lg:py-32">
        <div class="max-w-3xl">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-teal-100 text-teal-700 text-sm font-medium mb-6">
            <span class="w-2 h-2 rounded-full bg-teal-500"></span>
            Now accepting new patients
          </div>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-slate-900 leading-tight">
            Your health, <span class="text-teal-600">our priority</span>
          </h1>
          <p class="mt-6 text-lg md:text-xl text-slate-600 leading-relaxed max-w-2xl">
            The Integrated Health Professional Centre brings together family medicine,
            naturopathic care, and pain management specialists in one convenient
            Bedford location.
          </p>
          <div class="mt-8 flex flex-wrap gap-4">
            <a href="/clinics" class="btn btn-primary">
              Explore Our Clinics
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </a>
            <a href="/contact" class="btn btn-secondary">
              Get Directions
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Overview -->
  <section class="section bg-white">
    <div class="container">
      <div class="section-header">
        <h2>Comprehensive Healthcare Services</h2>
        <p>Three specialized practices working together to provide complete, coordinated care for you and your family.</p>
      </div>

      <div class="grid gap-8 md:grid-cols-3">
        {services.map((service) => (
          <div class="p-8 rounded-2xl bg-slate-50 hover:bg-teal-50 transition-colors group">
            <div class="w-12 h-12 rounded-xl bg-white shadow-sm flex items-center justify-center text-teal-600 group-hover:bg-teal-600 group-hover:text-white transition-colors">
              <Fragment set:html={service.icon} />
            </div>
            <h3 class="mt-5 text-xl font-semibold">{service.title}</h3>
            <p class="mt-3 text-slate-600">{service.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Clinics Section -->
  <section class="section gradient-subtle">
    <div class="container">
      <div class="section-header">
        <h2>Our Clinics</h2>
        <p>Each clinic operates independently while sharing resources and collaborating on patient care.</p>
      </div>

      <div class="grid gap-6 lg:grid-cols-3">
        {clinics.map((clinic) => (
          <a href={`/clinics/${clinic.slug}`} class="card group">
            <div class="p-6">
              <div class="flex items-start justify-between">
                <div>
                  <span class="badge">{clinic.type === "family-medicine" ? "Family Medicine" : clinic.type === "naturopathic" ? "Naturopathic" : "Pain Management"}</span>
                  <h3 class="mt-3 text-xl font-semibold group-hover:text-teal-600 transition-colors">{clinic.name}</h3>
                </div>
                <svg class="w-5 h-5 text-slate-400 group-hover:text-teal-600 group-hover:translate-x-1 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                </svg>
              </div>
              <p class="mt-3 text-slate-600">{clinic.tagline}</p>
              <div class="mt-4 pt-4 border-t border-slate-100">
                <p class="text-sm text-slate-500">
                  {clinic.doctors.length} {clinic.doctors.length === 1 ? "practitioner" : "practitioners"}
                </p>
              </div>
            </div>
          </a>
        ))}
      </div>

      <div class="mt-10 text-center">
        <a href="/clinics" class="btn btn-outline">
          View All Clinics & Practitioners
        </a>
      </div>
    </div>
  </section>

  <!-- Why Choose IHPC -->
  <section class="section bg-white">
    <div class="container">
      <div class="grid gap-12 lg:grid-cols-2 items-center">
        <div>
          <h2>Why Choose IHPC?</h2>
          <p class="mt-4 text-lg text-slate-600">
            Our integrated model brings together different healthcare disciplines
            in one location, making it easier for you to access the care you need.
          </p>
          <ul class="mt-8 list-check text-slate-700">
            {features.map((feature) => (
              <li>{feature}</li>
            ))}
          </ul>
          <div class="mt-8">
            <a href="/about" class="btn btn-secondary">
              Learn More About Us
            </a>
          </div>
        </div>
        <div class="relative">
          <div class="aspect-[4/3] rounded-2xl bg-gradient-to-br from-teal-100 to-cyan-100 flex items-center justify-center">
            <div class="text-center p-8">
              <div class="w-20 h-20 mx-auto rounded-full bg-white shadow-lg flex items-center justify-center">
                <svg class="w-10 h-10 text-teal-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3.75h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008z" />
                </svg>
              </div>
              <p class="mt-4 text-slate-600 font-medium">1378 Bedford Highway</p>
              <p class="text-slate-500">Bedford, NS B4A 1E2</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="section bg-gradient-to-r from-teal-600 to-teal-700">
    <div class="container">
      <div class="text-center max-w-2xl mx-auto">
        <h2 class="text-white">Ready to prioritize your health?</h2>
        <p class="mt-4 text-teal-100 text-lg">
          Contact one of our clinics today to schedule an appointment or learn more about our services.
        </p>
        <div class="mt-8 flex flex-wrap justify-center gap-4">
          <a href="/clinics" class="btn bg-white text-teal-700 hover:bg-teal-50">
            Find a Clinic
          </a>
          <a href="/contact" class="btn border-2 border-white text-white hover:bg-white/10">
            Contact Us
          </a>
        </div>
      </div>
    </div>
  </section>

  <Fragment slot="footer"><Footer /></Fragment>
</SiteLayout>
