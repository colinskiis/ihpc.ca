---
import SiteLayout from "../layouts/SiteLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---
<SiteLayout title="Disclaimer – Integrated Health Professional Centre">
  <Fragment slot="header"><Header /></Fragment>

  <!-- Page Header -->
  <section class="bg-gradient-to-br from-slate-50 via-white to-teal-50 py-12 md:py-16">
    <div class="container">
      <h1>Disclaimer</h1>
      <p class="mt-4 text-lg text-slate-600 max-w-2xl">
        Important information about the nature of content on this website.
      </p>
    </div>
  </section>

  <!-- Content -->
  <section class="section">
    <div class="container">
      <div class="max-w-3xl space-y-10">

        <div>
          <h2 class="text-2xl">Informational Purpose Only</h2>
          <p class="mt-4 text-slate-600">
            The content on this website is provided for general informational purposes only.
            Nothing on this site constitutes medical advice, diagnosis, or treatment. Always
            consult a qualified healthcare professional regarding any medical condition or
            treatment, and never disregard professional medical advice or delay seeking it
            because of something you have read here.
          </p>
        </div>

        <div>
          <h2 class="text-2xl">Independent Clinics</h2>
          <p class="mt-4 text-slate-600">
            IHPC is a co-owned building that houses independent healthcare practices.
            Each clinic — Monaghan Medical Clinic, Optimal Wellbeing Clinic, and the Chronic
            Pain Management Clinic — operates independently, maintains its own patient
            relationships, and is solely responsible for the care it provides.
          </p>
          <p class="mt-4 text-slate-600">
            IHPC does not provide medical services directly and is not responsible for the
            clinical decisions, advice, or outcomes of any individual clinic or practitioner.
          </p>
        </div>

        <div>
          <h2 class="text-2xl">Accuracy of Information</h2>
          <p class="mt-4 text-slate-600">
            While we make reasonable efforts to keep clinic information on this site current,
            details such as hours, practitioners, and services may change. Please contact the
            relevant clinic directly to confirm up-to-date information before making any
            decisions based on content found here.
          </p>
        </div>

        <div>
          <h2 class="text-2xl">External Links</h2>
          <p class="mt-4 text-slate-600">
            This site contains links to individual clinic websites and third-party booking
            platforms. IHPC does not control these external sites and is not responsible for
            their content, privacy practices, or availability.
          </p>
        </div>

        <div>
          <h2 class="text-2xl">Questions</h2>
          <p class="mt-4 text-slate-600">
            If you have questions about this disclaimer, please contact us:
          </p>
          <address class="mt-4 not-italic text-slate-600 space-y-1">
            <p>Integrated Health Professional Centre</p>
            <p>1378 Bedford Highway, Bedford, NS B4A 1E2</p>
            <p><a href="tel:902-800-3055" class="text-teal-600 hover:text-teal-700">902-800-3055</a></p>
          </address>
        </div>

      </div>
    </div>
  </section>

  <Fragment slot="footer"><Footer /></Fragment>
</SiteLayout>
