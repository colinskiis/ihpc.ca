---
import SiteLayout from "../../layouts/SiteLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import MapEmbed from "../../components/MapEmbed.astro";
import { clinics, getClinicBySlug } from "../../data/clinics";
import type { Clinic, Doctor } from "../../data/clinics";

export function getStaticPaths() {
  return clinics.map((clinic) => ({
    params: { slug: clinic.slug },
  }));
}

const { slug } = Astro.params;
const clinic = getClinicBySlug(slug as string);

if (!clinic) {
  return Astro.redirect("/clinics");
}

function getClinicTypeLabel(type: string): string {
  switch (type) {
    case "family-medicine": return "Family Medicine";
    case "naturopathic": return "Naturopathic";
    case "pain-management": return "Pain Management";
    default: return type;
  }
}
---
<SiteLayout title={`${clinic.name} – IHPC`}>
  <Fragment slot="header"><Header /></Fragment>

  <!-- Breadcrumb -->
  <div class="bg-slate-50 border-b">
    <div class="container py-3">
      <nav class="flex items-center gap-2 text-sm text-slate-500">
        <a href="/" class="hover:text-teal-600">Home</a>
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
        </svg>
        <a href="/clinics" class="hover:text-teal-600">Clinics</a>
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
        </svg>
        <span class="text-slate-900">{clinic.name}</span>
      </nav>
    </div>
  </div>

  <!-- Clinic Header -->
  <section class="bg-gradient-to-br from-slate-50 via-white to-teal-50 py-12 md:py-16">
    <div class="container">
      <div class="max-w-3xl">
        <span class="badge">{getClinicTypeLabel(clinic.type)}</span>
        <h1 class="mt-4">{clinic.name}</h1>
        <p class="mt-4 text-xl text-slate-600">{clinic.tagline}</p>

        <!-- Contact Info -->
        <div class="mt-8 flex flex-wrap gap-6">
          {clinic.phone && (
            <a href={`tel:${clinic.phone.replace(/\s+/g, '')}`} class="flex items-center gap-2 text-slate-700 hover:text-teal-600">
              <div class="w-10 h-10 rounded-lg bg-teal-100 flex items-center justify-center">
                <svg class="w-5 h-5 text-teal-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                </svg>
              </div>
              <div>
                <p class="text-sm text-slate-500">Phone</p>
                <p class="font-medium">{clinic.phone}</p>
              </div>
            </a>
          )}
          {clinic.hours && (
            <div class="flex items-center gap-2 text-slate-700">
              <div class="w-10 h-10 rounded-lg bg-teal-100 flex items-center justify-center">
                <svg class="w-5 h-5 text-teal-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <p class="text-sm text-slate-500">Hours</p>
                <p class="font-medium">{clinic.hours}</p>
              </div>
            </div>
          )}
          {clinic.url && (
            <a href={clinic.url} target="_blank" rel="noopener" class="flex items-center gap-2 text-slate-700 hover:text-teal-600">
              <div class="w-10 h-10 rounded-lg bg-teal-100 flex items-center justify-center">
                <svg class="w-5 h-5 text-teal-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" />
                </svg>
              </div>
              <div>
                <p class="text-sm text-slate-500">Website</p>
                <p class="font-medium">Visit Website</p>
              </div>
            </a>
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- Main Content -->
  <section class="section">
    <div class="container">
      <div class="grid gap-12 lg:grid-cols-3">
        <!-- Main Column -->
        <div class="lg:col-span-2 space-y-12">
          <!-- About -->
          <div>
            <h2 class="text-2xl">About {clinic.name}</h2>
            <p class="mt-4 text-lg text-slate-600 leading-relaxed">{clinic.description}</p>
          </div>

          <!-- Our Team -->
          <div>
            <h2 class="text-2xl">Our Team</h2>
            <div class="mt-6 space-y-8">
              {clinic.doctors.map((doctor) => (
                <div class="card p-6">
                  <div class="flex flex-col sm:flex-row gap-6">
                    {doctor.photo ? (
                      <img 
                        src={doctor.photo} 
                        alt={doctor.name} 
                        class="w-24 h-24 rounded-2xl object-cover shrink-0"
                      />
                    ) : (
                      <div class="w-24 h-24 rounded-2xl bg-gradient-to-br from-teal-400 to-teal-600 flex items-center justify-center text-white text-2xl font-semibold shrink-0">
                        {doctor.name.split(' ').slice(1).map(n => n[0]).join('')}
                      </div>
                    )}
                    <div class="flex-1">
                      <h3 class="text-xl">{doctor.name}, {doctor.credentials}</h3>
                      <p class="mt-3 text-slate-600">{doctor.bio}</p>

                      <!-- Education -->
                      {doctor.education && doctor.education.length > 0 && (
                        <div class="mt-4">
                          <h4 class="text-sm font-semibold text-slate-900 uppercase tracking-wide">Education & Training</h4>
                          <ul class="mt-2 space-y-1 text-sm text-slate-600">
                            {doctor.education.map((edu) => (
                              <li class="flex items-start gap-2">
                                <svg class="w-4 h-4 text-teal-500 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                                </svg>
                                {edu}
                              </li>
                            ))}
                          </ul>
                        </div>
                      )}

                      <!-- Specialties -->
                      {doctor.specialties && doctor.specialties.length > 0 && (
                        <div class="mt-4">
                          <h4 class="text-sm font-semibold text-slate-900 uppercase tracking-wide">Areas of Focus</h4>
                          <div class="mt-2 flex flex-wrap gap-2">
                            {doctor.specialties.map((specialty) => (
                              <span class="px-3 py-1 bg-teal-50 text-teal-700 text-sm rounded-full">{specialty}</span>
                            ))}
                          </div>
                        </div>
                      )}

                      <!-- Booking -->
                      {doctor.bookingUrl && (
                        <div class="mt-6">
                          <a href={doctor.bookingUrl} target="_blank" rel="noopener" class="btn btn-primary">
                            Book with Dr. {doctor.name.split(' ').slice(-1)[0]}
                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
                            </svg>
                          </a>
                        </div>
                      )}
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- Sidebar -->
        <div class="space-y-8">
          <!-- Services Card -->
          <div class="card p-6">
            <h3 class="text-lg font-semibold">Services Offered</h3>
            <ul class="mt-4 space-y-3">
              {clinic.services.map((service) => (
                <li class="flex items-start gap-3 text-slate-600">
                  <svg class="w-5 h-5 text-teal-500 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  {service}
                </li>
              ))}
            </ul>
          </div>

          <!-- Location Card -->
          <div class="card p-6">
            <h3 class="text-lg font-semibold">Location</h3>
            <div class="mt-4">
              <p class="text-slate-600">
                1378 Bedford Highway<br />
                Bedford, NS B4A 1E2
              </p>
              <a
                href={`https://maps.google.com/?q=${encodeURIComponent(clinic.address)}`}
                target="_blank"
                rel="noopener"
                class="mt-4 inline-flex items-center gap-2 text-teal-600 hover:text-teal-700 font-medium"
              >
                Get Directions
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                </svg>
              </a>
              <div class="mt-4">
                <MapEmbed address={clinic.address} />
              </div>
            </div>
          </div>

          <!-- Contact Card -->
          <div class="card p-6 bg-teal-50 border-teal-100">
            <h3 class="text-lg font-semibold">Get in Touch</h3>
            <p class="mt-2 text-slate-600">
              Call this clinic directly for information about services or to speak with their team.
            </p>
            {clinic.phone && (
              <a href={`tel:${clinic.phone.replace(/\s+/g, '')}`} class="mt-4 btn btn-primary w-full justify-center">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                </svg>
                Call {clinic.phone}
              </a>
            )}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Back to Clinics -->
  <section class="pb-16">
    <div class="container">
      <a href="/clinics" class="inline-flex items-center gap-2 text-slate-600 hover:text-teal-600 font-medium">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
        </svg>
        Back to All Clinics
      </a>
    </div>
  </section>

  <Fragment slot="footer"><Footer /></Fragment>
</SiteLayout>
