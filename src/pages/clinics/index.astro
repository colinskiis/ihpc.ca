---
import SiteLayout from "../../layouts/SiteLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { clinics } from "../../data/clinics";

function getClinicTypeLabel(type: string): string {
  switch (type) {
    case "family-medicine": return "Family Medicine";
    case "naturopathic": return "Naturopathic";
    case "pain-management": return "Pain Management";
    default: return type;
  }
}
---
<SiteLayout title="Clinics – Integrated Health Professional Centre">
  <Fragment slot="header"><Header /></Fragment>

  <!-- Page Header -->
  <section class="bg-gradient-to-br from-slate-50 via-white to-teal-50 py-12 md:py-16">
    <div class="container">
      <h1>Our Clinics</h1>
      <p class="mt-4 text-lg text-slate-600 max-w-2xl">
        Each clinic at IHPC operates independently while sharing our beautiful facility
        and collaborating on patient care. Find the right practitioner for your healthcare needs.
      </p>
    </div>
  </section>

  <!-- Clinics List -->
  <section class="section">
    <div class="container">
      <div class="space-y-12">
        {clinics.map((clinic) => (
          <div class="card overflow-visible">
            <div class="p-8">
              <!-- Clinic Header -->
              <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4">
                <div>
                  <span class="badge">{getClinicTypeLabel(clinic.type)}</span>
                  <h2 class="mt-3">{clinic.name}</h2>
                  <p class="mt-2 text-lg text-slate-600">{clinic.tagline}</p>
                </div>
                <div class="flex flex-col gap-2 text-sm">
                  {clinic.phone && (
                    <a href={`tel:${clinic.phone.replace(/\s+/g, '')}`} class="flex items-center gap-2 text-slate-600 hover:text-teal-600">
                      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                      </svg>
                      {clinic.phone}
                    </a>
                  )}
                  {clinic.hours && (
                    <span class="flex items-center gap-2 text-slate-500">
                      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                      </svg>
                      {clinic.hours}
                    </span>
                  )}
                </div>
              </div>

              <p class="mt-4 text-slate-600">{clinic.description}</p>

              <!-- Services -->
              <div class="mt-6">
                <h4 class="text-sm font-semibold text-slate-900 uppercase tracking-wide">Services</h4>
                <div class="mt-3 flex flex-wrap gap-2">
                  {clinic.services.slice(0, 6).map((service) => (
                    <span class="px-3 py-1 bg-slate-100 text-slate-700 text-sm rounded-full">{service}</span>
                  ))}
                  {clinic.services.length > 6 && (
                    <span class="px-3 py-1 bg-slate-100 text-slate-500 text-sm rounded-full">+{clinic.services.length - 6} more</span>
                  )}
                </div>
              </div>

              <!-- Practitioners -->
              <div class="mt-8 pt-8 border-t border-slate-200">
                <h4 class="text-sm font-semibold text-slate-900 uppercase tracking-wide mb-4">Practitioners</h4>
                <div class="grid gap-6 md:grid-cols-2">
                  {clinic.doctors.map((doctor) => (
                    <div class="flex gap-4 p-4 rounded-xl bg-slate-50 hover:bg-teal-50 transition-colors">
                      {doctor.photo ? (
                        <img 
                          src={doctor.photo} 
                          alt={doctor.name} 
                          class="w-16 h-16 rounded-full object-cover shrink-0"
                        />
                      ) : (
                        <div class="w-16 h-16 rounded-full bg-gradient-to-br from-teal-400 to-teal-600 flex items-center justify-center text-white text-xl font-semibold shrink-0">
                          {doctor.name.split(' ').slice(1).map(n => n[0]).join('')}
                        </div>
                      )}
                      <div class="min-w-0">
                        <h5 class="font-semibold text-slate-900">{doctor.name}, {doctor.credentials}</h5>
                        <p class="mt-1 text-sm text-slate-600 line-clamp-2">{doctor.bio}</p>
                        <div class="mt-2 flex flex-wrap gap-2">
                          {doctor.bookingUrl && (
                            <a href={doctor.bookingUrl} target="_blank" rel="noopener" class="text-sm text-teal-600 hover:text-teal-700 font-medium">
                              Book Online
                            </a>
                          )}
                        </div>
                      </div>
                    </div>
                  ))}
                </div>
              </div>

              <!-- Actions -->
              <div class="mt-8 flex flex-wrap gap-4">
                <a href={`/clinics/${clinic.slug}`} class="btn btn-primary">
                  View Full Details
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                  </svg>
                </a>
                {clinic.url && (
                  <a href={clinic.url} target="_blank" rel="noopener" class="btn btn-secondary">
                    Visit Website
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
                    </svg>
                  </a>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Fragment slot="footer"><Footer /></Fragment>
</SiteLayout>
