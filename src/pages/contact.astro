---
import SiteLayout from "../layouts/SiteLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { clinics } from "../data/clinics";
---
<SiteLayout title="Contact – Integrated Health Professional Centre">
  <Fragment slot="header"><Header /></Fragment>

  <!-- Page Header -->
  <section class="bg-gradient-to-br from-slate-50 via-white to-teal-50 py-12 md:py-16">
    <div class="container">
      <h1>Contact Us</h1>
      <p class="mt-4 text-lg text-slate-600 max-w-2xl">
        Get in touch with IHPC or contact our clinics directly for appointments and inquiries.
      </p>
    </div>
  </section>

  <!-- Contact Content -->
  <section class="section">
    <div class="container">
      <div class="grid gap-12 lg:grid-cols-2">
        <!-- Contact Info -->
        <div>
          <h2>Get in Touch</h2>
          <p class="mt-4 text-slate-600">
            For general inquiries about the building or shared services, please use the
            contact information below. For medical appointments and clinic-specific
            questions, please contact clinics directly.
          </p>

          <!-- Address Card -->
          <div class="mt-8 card p-6">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-xl bg-teal-100 flex items-center justify-center shrink-0">
                <svg class="w-6 h-6 text-teal-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                </svg>
              </div>
              <div>
                <h3 class="text-lg font-semibold">Address</h3>
                <p class="mt-1 text-slate-600">
                  1378 Bedford Highway<br />
                  Bedford, NS B4A 1E2
                </p>
                <a
                  href="https://maps.google.com/?q=1378+Bedford+Highway,+Bedford,+NS+B4A+1E2"
                  target="_blank"
                  rel="noopener"
                  class="mt-3 inline-flex items-center gap-2 text-teal-600 hover:text-teal-700 font-medium"
                >
                  Get Directions
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
                  </svg>
                </a>
              </div>
            </div>
          </div>

          <!-- Clinic Contacts -->
          <div class="mt-8">
            <h3 class="text-xl font-semibold">Clinic Contact Information</h3>
            <p class="mt-2 text-slate-600">
              Contact clinics directly for appointments and medical inquiries:
            </p>

            <div class="mt-6 space-y-4">
              {clinics.map((clinic) => (
                <div class="p-4 rounded-xl bg-slate-50 hover:bg-teal-50 transition-colors">
                  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
                    <div>
                      <h4 class="font-semibold text-slate-900">{clinic.name}</h4>
                      {clinic.phone && (
                        <a href={`tel:${clinic.phone.replace(/\s+/g, '')}`} class="text-teal-600 hover:text-teal-700">
                          {clinic.phone}
                        </a>
                      )}
                    </div>
                    <a href={`/clinics/${clinic.slug}`} class="text-sm text-slate-500 hover:text-teal-600">
                      View Details
                    </a>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- Map -->
        <div>
          <div class="card overflow-hidden h-full min-h-[400px]">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2837.8076040881545!2d-63.66583492402927!3d44.72729097107098!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x4b5a21d41c2b4e5d%3A0x8f1c8f1c8f1c8f1c!2s1378%20Bedford%20Hwy%2C%20Bedford%2C%20NS%20B4A%201E2!5e0!3m2!1sen!2sca!4v1699000000000!5m2!1sen!2sca"
              class="w-full h-full min-h-[400px]"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="IHPC Location Map"
            ></iframe>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Parking & Accessibility -->
  <section class="section bg-white">
    <div class="container">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-center">Getting Here</h2>
        <p class="mt-4 text-center text-slate-600">
          We're conveniently located on Bedford Highway with easy access by car or transit.
        </p>

        <div class="mt-8 grid gap-6 md:grid-cols-3">
          <div class="text-center p-6">
            <div class="w-14 h-14 mx-auto rounded-2xl bg-teal-100 flex items-center justify-center">
              <svg class="w-7 h-7 text-teal-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" />
              </svg>
            </div>
            <h3 class="mt-4 font-semibold">Free Parking</h3>
            <p class="mt-2 text-sm text-slate-600">On-site parking available for all patients</p>
          </div>

          <div class="text-center p-6">
            <div class="w-14 h-14 mx-auto rounded-2xl bg-teal-100 flex items-center justify-center">
              <svg class="w-7 h-7 text-teal-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25m-2.25 0V5.625m0 0a3 3 0 00-3-3H6.75a3 3 0 00-3 3v.75" />
              </svg>
            </div>
            <h3 class="mt-4 font-semibold">Transit Access</h3>
            <p class="mt-2 text-sm text-slate-600">Bedford Highway bus routes stop nearby</p>
          </div>

          <div class="text-center p-6">
            <div class="w-14 h-14 mx-auto rounded-2xl bg-teal-100 flex items-center justify-center">
              <svg class="w-7 h-7 text-teal-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
              </svg>
            </div>
            <h3 class="mt-4 font-semibold">Accessible</h3>
            <p class="mt-2 text-sm text-slate-600">Fully accessible entrance and facilities</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Fragment slot="footer"><Footer /></Fragment>
</SiteLayout>
