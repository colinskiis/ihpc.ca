---
import { clinics } from "../data/clinics";

const quickLinks = [
  { href: "/", label: "Home" },
  { href: "/about", label: "About Us" },
  { href: "/clinics", label: "Our Clinics" },
  { href: "/contact", label: "Contact" },
];
---
<footer class="bg-slate-900 text-slate-300">
  <div class="container py-12 md:py-16">
    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-4">
      <!-- Brand -->
      <div class="lg:col-span-1">
        <a href="/" class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-lg bg-teal-600 flex items-center justify-center">
            <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
            </svg>
          </div>
          <span class="font-semibold text-white">IHPC</span>
        </a>
        <p class="mt-4 text-sm">
          Integrated Health Professional Centre brings together family medicine,
          naturopathic care, and pain management under one roof.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="text-white font-semibold mb-4">Quick Links</h4>
        <ul class="space-y-2">
          {quickLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm hover:text-teal-400 transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Clinics -->
      <div>
        <h4 class="text-white font-semibold mb-4">Our Clinics</h4>
        <ul class="space-y-2">
          {clinics.map((clinic) => (
            <li>
              <a href={`/clinics/${clinic.slug}`} class="text-sm hover:text-teal-400 transition-colors">
                {clinic.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="text-white font-semibold mb-4">Contact</h4>
        <address class="not-italic text-sm space-y-2">
          <p>1378 Bedford Highway</p>
          <p>Bedford, NS B4A 1E2</p>
          <p class="pt-2">
            <a href="tel:902-800-3055" class="hover:text-teal-400 transition-colors">
              902-800-3055
            </a>
          </p>
        </address>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="mt-12 pt-8 border-t border-slate-800">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="text-sm text-slate-400">
          &copy; {new Date().getFullYear()} Integrated Health Professional Centre. All rights reserved.
        </p>
        <div class="flex flex-wrap items-center gap-4 text-sm text-slate-500">
          <span>Each clinic operates independently within IHPC.</span>
          <span class="hidden md:inline text-slate-700">·</span>
          <a href="/privacy" class="hover:text-teal-400 transition-colors">Privacy Policy</a>
          <a href="/disclaimer" class="hover:text-teal-400 transition-colors">Disclaimer</a>
        </div>
      </div>
    </div>
  </div>
</footer>
