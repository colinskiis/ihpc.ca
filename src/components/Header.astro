---
const nav = [
  { href: "/", label: "Home" },
  { href: "/about", label: "About" },
  { href: "/clinics", label: "Clinics" },
  { href: "/contact", label: "Contact" },
];

const currentPath = Astro.url.pathname;
---
<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-md border-b border-slate-200/80">
  <div class="container">
    <div class="flex items-center justify-between h-16 md:h-18">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 group">
        <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-teal-500 to-teal-600 flex items-center justify-center shadow-sm">
          <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
          </svg>
        </div>
        <div class="hidden sm:block">
          <span class="font-semibold text-slate-900 tracking-tight">IHPC</span>
          <span class="hidden lg:inline text-slate-500 font-normal"> | Integrated Health Professional Centre</span>
        </div>
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden md:flex items-center gap-1">
        {nav.map((item) => {
          const isActive = currentPath === item.href ||
            (item.href !== "/" && currentPath.startsWith(item.href));
          return (
            <a
              href={item.href}
              aria-current={isActive ? "page" : undefined}
              class:list={[
                "px-4 py-2 rounded-lg text-sm font-medium transition-colors",
                isActive
                  ? "bg-teal-50 text-teal-700"
                  : "text-slate-600 hover:text-slate-900 hover:bg-slate-100"
              ]}
            >
              {item.label}
            </a>
          );
        })}
      </nav>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 rounded-lg text-slate-600 hover:bg-slate-100"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="md:hidden hidden border-t border-slate-200 bg-white">
    <nav class="container py-4 flex flex-col gap-1">
      {nav.map((item) => {
        const isActive = currentPath === item.href ||
          (item.href !== "/" && currentPath.startsWith(item.href));
        return (
          <a
            href={item.href}
            aria-current={isActive ? "page" : undefined}
            class:list={[
              "px-4 py-3 rounded-lg text-sm font-medium transition-colors",
              isActive
                ? "bg-teal-50 text-teal-700"
                : "text-slate-600 hover:bg-slate-100"
            ]}
          >
            {item.label}
          </a>
        );
      })}
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn') as HTMLButtonElement | null;
  const menu = document.getElementById('mobile-menu');

  function setMenuOpen(open: boolean) {
    menu?.classList.toggle('hidden', !open);
    btn?.setAttribute('aria-expanded', String(open));
  }

  btn?.addEventListener('click', () => {
    const isOpen = btn.getAttribute('aria-expanded') === 'true';
    setMenuOpen(!isOpen);
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && btn?.getAttribute('aria-expanded') === 'true') {
      setMenuOpen(false);
      btn.focus();
    }
  });
</script>
